<view class="title-group">
    <block wx:for="{{ order_type_list }}" wx:key="index">
        <view data-index="{{index}}" bindtap="select" style="display: flex;flex-direction: column;align-items: center;">
            <text class="{{ select_tap == index ? 'text-select' : 'text-no-select'}}">
                {{item.text}}
            </text>
            <view class="{{select_tap == index ? 'bottom-line' : 'white-bottom-line'}}">
            </view>
        </view>
    </block>
</view>

<scroll-view scroll-y="true">
    <order_list list="{{history_list}}" wx:if="{{select_tap == 0}}"></order_list>
    <order_list list="{{current_list}}" wx:if="{{select_tap == 1}}"></order_list>
</scroll-view>